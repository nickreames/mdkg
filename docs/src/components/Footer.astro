---
import DefaultFooter from "@astrojs/starlight/components/Footer.astro";
import { currentRelease } from "../data/currentRelease.mjs";
import CurrentReleaseSupplement from "./CurrentReleaseSupplement.astro";

const routeVariants = new Map([
  ["/start-here/install/", "install"],
  ["/project/changelog/", "changelog"],
  ["/reference/generated-cli-reference/", "reference"],
]);
const variant = routeVariants.get(Astro.url.pathname);
---

{currentRelease.visible && variant && (
  <CurrentReleaseSupplement variant={variant} release={currentRelease} />
)}
<DefaultFooter />
