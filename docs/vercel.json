{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mdkg-docs.vercel.app"
        }
      ],
      "destination": "https://docs.mdkg.dev/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mdkg-docs-nicholas-reames-projects.vercel.app"
        }
      ],
      "destination": "https://docs.mdkg.dev/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mdkg-docs-git-main-nicholas-reames-projects.vercel.app"
        }
      ],
      "destination": "https://docs.mdkg.dev/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": ".*\\.vercel\\.app$"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
