---
const { padded = true } = Astro.props;
---

<article class:list={["card", { padded }]}>
  <slot />
</article>

<style>
  .card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: var(--shadow);
  }

  .padded {
    padding: 22px;
  }
</style>
