---
const { title = "Terminal", commands } = Astro.props as { title?: string; commands: string[] };
const commandText = commands.join("\n");
---

<figure class="terminal">
  <figcaption>
    <span aria-hidden="true"></span>
    {title}
  </figcaption>
  <pre><code>{commandText}</code></pre>
</figure>

<style>
  .terminal {
    align-self: start;
    margin: 0;
    overflow: hidden;
    border: 1px solid rgba(15, 23, 42, 0.14);
    border-radius: var(--radius);
    background: #0f172a;
    box-shadow: var(--shadow);
  }

  figcaption {
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 10px 14px;
    color: #bae6fd;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  figcaption span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #14b8a6;
  }

  pre {
    margin: 0;
    padding: 16px;
    overflow-x: auto;
  }

  code {
    display: block;
    color: #e0f2fe;
    font-size: 0.9rem;
    line-height: 1.6;
    white-space: pre;
  }
</style>
