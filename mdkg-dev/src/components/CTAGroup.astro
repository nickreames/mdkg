---
import ButtonLink from "./ButtonLink.astro";

const {
  primaryHref = "/quickstart/",
  secondaryHref = "https://github.com/nickreames/mdkg",
  tertiaryHref = String(
    import.meta.env.PUBLIC_MDKG_DOCS_URL || "https://mdkg-docs.vercel.app/"
  ),
  primaryLabel = "Get started",
  secondaryLabel = "View GitHub",
  tertiaryLabel = "Read docs"
} = Astro.props;
---

<div class="cta-group" aria-label="Primary actions">
  <ButtonLink href={primaryHref}>{primaryLabel}</ButtonLink>
  <ButtonLink href={secondaryHref} variant="secondary">{secondaryLabel}</ButtonLink>
  <ButtonLink href={tertiaryHref} variant="ghost">{tertiaryLabel}</ButtonLink>
</div>

<style>
  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-top: 28px;
  }

  @media (max-width: 560px) {
    .cta-group {
      align-items: stretch;
      flex-direction: column;
    }

    .cta-group :global(.button) {
      width: 100%;
    }
  }
</style>
