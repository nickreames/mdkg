---
const docsUrl = String(
  import.meta.env.PUBLIC_MDKG_DOCS_URL || "https://mdkg-docs.vercel.app/"
);

const links = [
  { href: "/quickstart/", label: "Quickstart" },
  { href: docsUrl, label: "Docs ↗", external: true },
  { href: "https://github.com/nickreames/mdkg", label: "GitHub ↗", external: true },
  { href: "https://www.npmjs.com/package/mdkg", label: "npm ↗", external: true }
];
---

<nav class="nav" aria-label="Main navigation">
  <a class="brand" href="/">
    <span>mdkg</span>
  </a>
  <div class="links">
    {links.map((link) => (
      <a
        href={link.href}
        target={link.external ? "_blank" : undefined}
        rel={link.external ? "noopener noreferrer" : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .nav {
    display: flex;
    width: min(1120px, calc(100% - 32px));
    min-height: 68px;
    margin: 0 auto;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .brand,
  .links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand {
    font-weight: 800;
    text-decoration: none;
  }

  .links {
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .links a {
    color: var(--zinc-700);
    font-size: 0.94rem;
    font-weight: 650;
    text-decoration: none;
  }

  .links a:hover {
    color: var(--blue-700);
  }

  @media (max-width: 680px) {
    .nav {
      align-items: flex-start;
      flex-direction: column;
      padding: 16px 0;
    }

    .links {
      justify-content: flex-start;
    }
  }
</style>
