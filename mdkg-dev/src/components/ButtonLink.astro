---
type Variant = "primary" | "secondary" | "ghost";
const { href, variant = "primary" } = Astro.props as { href: string; variant?: Variant };
const isExternal = /^https?:\/\//.test(href);
---

<a
  class={`button ${variant}`}
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
>
  <slot />
</a>

<style>
  .button {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: var(--radius);
    padding: 10px 16px;
    border: 1px solid var(--border);
    font-weight: 700;
    text-decoration: none;
    text-align: center;
    white-space: normal;
  }

  .primary {
    color: white;
    border-color: transparent;
    background: linear-gradient(135deg, var(--blue-700), var(--sky-500), var(--teal-500));
  }

  .secondary {
    color: var(--zinc-950);
    background: var(--white);
  }

  .ghost {
    color: var(--zinc-700);
    background: transparent;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .button:hover {
      transform: none;
    }
  }
</style>
