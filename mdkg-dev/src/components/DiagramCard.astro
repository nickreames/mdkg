---
const { title, steps } = Astro.props as { title: string; steps: string[] };
---

<article class="diagram-card" aria-label={title}>
  <h3>{title}</h3>
  <div class="diagram">
    {steps.map((step, index) => (
      <div class="diagram-node">
        <span>{index + 1}</span>
        <strong>{step}</strong>
      </div>
    ))}
  </div>
</article>

<style>
  .diagram-card {
    padding: 22px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: var(--shadow);
  }

  h3 {
    margin-bottom: 18px;
  }

  .diagram {
    display: grid;
    gap: 12px;
  }

  .diagram-node {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 12px;
    align-items: center;
    padding: 12px;
    border: 1px solid rgba(14, 165, 233, 0.24);
    border-radius: var(--radius);
    background: linear-gradient(90deg, var(--sky-50), var(--white));
  }

  span {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border-radius: var(--radius);
    color: white;
    background: linear-gradient(135deg, var(--blue-700), var(--teal-500));
    font-family: var(--font-mono);
  }
</style>
