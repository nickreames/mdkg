---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import FeatureCard from "../components/FeatureCard.astro";
---

<BaseLayout title="mdkg Docs" description="Documentation entry points for Markdown Knowledge Graph.">
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Docs"
        level="h1"
        title="Repo-owned docs, rendered with Starlight."
        text="The mdkg repo remains the canonical docs source. Starlight is the docs renderer for the docs experience. During preview, use the hosted docs preview; later docs.mdkg.dev becomes the canonical docs host."
      />
      <div class="grid three">
        <FeatureCard title="Golden path" text="Install, initialize, index, validate, inspect status, pack context, and create a checkpoint before closeout." />
        <FeatureCard title="Agent workflows" text="Goals, tasks, spikes, checkpoints, handoffs, skills, subgraphs, and validation patterns for repo-scoped agents." />
        <FeatureCard title="Reference" text="Generated CLI command reference, output formats, node fields, config, project DB queues, and rebuildable indexes." />
      </div>
      <div class="docs-note">
        <h2>Preview bridge</h2>
        <p>
          This page intentionally stays lightweight. The marketing site explains why mdkg exists;
          the Starlight docs teach the operating loop and command details. Until DNS is cut over,
          the preview docs URL is the live review target and <code>https://docs.mdkg.dev</code>
          remains the future canonical docs address.
        </p>
        <p><code>https://mdkg-docs.vercel.app</code></p>
      </div>
      <div class="docs-actions" aria-label="Documentation actions">
        <a class="primary-link" href="https://mdkg-docs.vercel.app/">Open preview docs</a>
        <a class="secondary-link" href="https://docs.mdkg.dev">Future docs.mdkg.dev</a>
        <a class="secondary-link" href="https://github.com/nickreames/mdkg/tree/main/docs">View repo docs source</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .docs-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .docs-note {
    max-width: 820px;
    margin-top: 28px;
    padding: 22px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--white);
  }

  .docs-note h2 {
    margin: 0 0 10px;
    font-size: 1.08rem;
  }

  .docs-note p {
    margin: 0;
    color: var(--zinc-600);
  }

  code {
    font-size: 0.92em;
  }

  .primary-link,
  .secondary-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 10px 14px;
    border-radius: var(--radius);
    font-weight: 700;
    text-decoration: none;
  }

  .primary-link {
    color: var(--white);
    background: var(--zinc-950);
  }

  .secondary-link {
    border: 1px solid var(--border);
    color: var(--zinc-900);
    background: var(--white);
  }
</style>
