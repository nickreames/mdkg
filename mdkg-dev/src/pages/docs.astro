---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAGroup from "../components/CTAGroup.astro";
import SectionHeader from "../components/SectionHeader.astro";
import FeatureCard from "../components/FeatureCard.astro";

const docsUrl = String(
  import.meta.env.PUBLIC_MDKG_DOCS_URL || "https://mdkg-docs.vercel.app/"
);
---

<BaseLayout
  title="mdkg Docs"
  description="Read the Markdown Knowledge Graph documentation on the dedicated docs site."
  noindex={true}
>
  <section class="section">
    <div class="container grid two">
      <div class="stack">
        <SectionHeader
          eyebrow="Docs"
          level="h1"
          title="Read the mdkg docs on the dedicated docs site."
          text="The marketing site stays focused on the product overview. Until docs.mdkg.dev DNS is live, preview docs open on the dedicated Vercel docs preview with install steps, quickstart guidance, concepts, guides, and generated command reference."
        />
        <CTAGroup
          primaryHref={docsUrl}
          primaryLabel="Open docs"
          secondaryHref="/quickstart/"
          secondaryLabel="Run quickstart"
          tertiaryHref="https://github.com/nickreames/mdkg"
          tertiaryLabel="View GitHub"
        />
      </div>
      <div class="grid">
        <FeatureCard title="Start here" text="Install mdkg, initialize a repository, and run the first Plan -> Work -> Evidence loop." command="mdkg init --agent" />
        <FeatureCard title="Reference" text="Use the generated command reference for current CLI usage and output boundaries." command="mdkg help" />
        <FeatureCard title="Agent workflows" text="Learn how packs, handoffs, checkpoints, and validation keep work bounded." command="mdkg handoff create WORK_ID" />
      </div>
    </div>
  </section>
</BaseLayout>
