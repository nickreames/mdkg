---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAGroup from "../components/CTAGroup.astro";
import SectionHeader from "../components/SectionHeader.astro";
import TerminalBlock from "../components/TerminalBlock.astro";
import FeatureCard from "../components/FeatureCard.astro";
import DiagramCard from "../components/DiagramCard.astro";
import Badge from "../components/Badge.astro";
import packageJson from "../../../package.json";

const publishedPackageVersion = packageJson.version;
const launchTrackVersion = "0.4.0";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Markdown Knowledge Graph",
  alternateName: "mdkg",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux, Windows",
  softwareVersion: publishedPackageVersion,
  description: "Git-native project memory for AI coding agents: structured Markdown, context packs, handoffs, checkpoints, and validation.",
  url: "https://mdkg.dev",
  codeRepository: "https://github.com/nickreames/mdkg"
};
---

<BaseLayout
  title="Markdown Knowledge Graph - Git-native project memory for AI coding agents"
  description="Markdown Knowledge Graph gives AI coding agents a repo-owned Plan -> Work -> Evidence loop with structured Markdown, deterministic packs, handoffs, checkpoints, and validation."
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Markdown Knowledge Graph</p>
        <h1>Git-native project memory for AI coding agents.</h1>
        <p class="lead">Give agents one durable loop: plan the goal, work one node, record evidence, and validate before the next session continues.</p>
        <p class="trust-line">Pre-v1 public alpha. Markdown in your repo is the source of truth; no hosted index, daemon, or vector database is required.</p>
        <CTAGroup />
      </div>
      <DiagramCard
        title="Plan -> Work -> Evidence"
        steps={["Plan the goal", "Execute one work node", "Record evidence", "Validate before moving on"]}
      />
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div class="stack">
        <Badge>Quickstart</Badge>
        <h2>First, prove the loop locally.</h2>
        <p class="muted">Install mdkg, initialize repo-local project memory, rebuild the access cache, inspect status, and validate graph health before handing work to an agent.</p>
      </div>
      <div class="grid">
        <TerminalBlock
          title="First-run setup"
          commands={["npm install -g mdkg", "mdkg --version", "mdkg init --agent", "mdkg index", "mdkg status", "mdkg validate"]}
        />
        <TerminalBlock
          title="First-success path"
          commands={["mdkg goal current", "mdkg goal next", "mdkg show WORK_ID", "mdkg pack WORK_ID", "mdkg handoff create WORK_ID", "mdkg task done TASK_ID --checkpoint \"Meaningful milestone\"", "mdkg validate"]}
        />
      </div>
    </div>
  </section>

  <section class="section alt thesis-section">
    <div class="container grid two">
      <div class="stack">
        <Badge tone="teal">Why it matters</Badge>
        <h2>Bigger context helps. It does not replace project memory.</h2>
        <p class="muted">Longer context windows let an agent hold more text. Project memory gives that text durable shape: goals, decisions, active work, evidence, and checks in Git.</p>
        <p class="muted">One concrete change: the agent starts from work, not vibes.</p>
        <CTAGroup primaryHref="/quickstart/" primaryLabel="Try the quickstart" secondaryHref={String(import.meta.env.PUBLIC_MDKG_DOCS_URL || "https://docs.mdkg.dev/")} secondaryLabel="Read docs" tertiaryHref="https://github.com/nickreames/mdkg" tertiaryLabel="View GitHub" />
      </div>
      <div class="comparison-grid" aria-label="Context comparison">
        <article class="comparison-card">
          <h3>Without mdkg</h3>
          <ul>
            <li>current goal lives in chat</li>
            <li>required checks are easy to miss</li>
            <li>handoff depends on memory</li>
          </ul>
        </article>
        <article class="comparison-card positive">
          <h3>With mdkg</h3>
          <ul>
            <li>work nodes carry status and refs</li>
            <li>packs bound agent context</li>
            <li>checkpoints record proof</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeader
        eyebrow="Operating model"
        title="Plan -> Work -> Evidence"
        text="The public model is intentionally small: decide the goal, work one bounded node, then record proof before the next agent continues."
      />
      <div class="pwe-grid" aria-label="Plan Work Evidence model">
        <article class="pwe-card plan-card">
          <span class="pwe-label">01 / Plan</span>
          <h3>Plan the goal.</h3>
          <p>Goals, epics, PRDs, engineering designs, decisions, and rules describe what matters before an agent starts editing.</p>
          <code>goal-1 -> epic-1 -> dec-1</code>
        </article>
        <article class="pwe-card work-card">
          <span class="pwe-label">02 / Work</span>
          <h3>Execute one work node.</h3>
          <p>Features, tasks, bugs, tests, and research spikes give coding sessions a bounded unit with status, blockers, and checks.</p>
          <code>mdkg goal next</code>
        </article>
        <article class="pwe-card evidence-card">
          <span class="pwe-label">03 / Evidence</span>
          <h3>Record evidence.</h3>
          <p>Checkpoints, receipts, archives, validation output, and handoffs record why the current state is safe to continue from.</p>
          <code>mdkg task done TASK_ID --checkpoint "..."</code>
        </article>
      </div>
      <div class="proof-card compact-proof" aria-label="Example mdkg graph shape">
        <div class="path-line">.mdkg/work/goal-1-ship-a-feature.md</div>
        <dl>
          <div><dt>scope_refs</dt><dd>task-1, task-2, test-1</dd></div>
          <div><dt>context_refs</dt><dd>prd-1, dec-1, archive://research-notes</dd></div>
          <div><dt>evidence_refs</dt><dd>chk-1, test receipts, review notes</dd></div>
        </dl>
        <div class="proof-footer">one reviewable graph, one packable handoff, one validation loop</div>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeader
        eyebrow="Work model"
        title="Built around familiar SDLC shapes."
        text="mdkg models software work with graph nodes that humans already understand and agents can route through deterministically."
      />
      <div class="grid three">
        <FeatureCard title="Goals, epics, and features" text="Preserve intent across sessions, branches, and handoffs." command="mdkg goal current" />
        <FeatureCard title="Tasks, bugs, tests, and spikes" text="Give each coding session one actionable slice." command="mdkg goal next" />
        <FeatureCard title="Checkpoints and evidence" text="Record commands, pass/fail state, warnings, and boundaries." command="mdkg checkpoint new" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div class="stack">
        <Badge tone="teal">Local-first trust</Badge>
        <h2>Boring files beat mystery memory.</h2>
        <p class="muted">Markdown stays readable. Frontmatter gives machines structure. Git gives review, history, branching, and collaboration. Generated indexes stay rebuildable.</p>
      </div>
      <div class="grid">
        <FeatureCard title="Source files" text="Rules, decisions, PRDs, work nodes, checkpoints, skills, and archive sidecars live in the repo." command=".mdkg/" />
        <FeatureCard title="Generated access" text="Indexes and packs make retrieval fast without becoming hidden authority." command="mdkg index" />
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container grid two">
      <div class="stack">
        <Badge tone="neutral">{launchTrackVersion} launch track</Badge>
        <h2>Customize standards without forking the kernel.</h2>
        <p class="muted">The {launchTrackVersion} web launch presents capabilities already available in `mdkg@{publishedPackageVersion}` while structured package metadata stays tied to the published npm version. Local validation happens before publish; live validation follows the approved publish and deploy.</p>
      </div>
      <div class="grid">
        <FeatureCard title="Published package baseline" text={`Install and structured metadata stay anchored to mdkg@${publishedPackageVersion} until the next npm package is actually published.`} command="mdkg --version" />
        <FeatureCard title="Config overlays" text="Use `.mdkg/config.json` to preserve local standards, custom core docs, and managed upgrade behavior." command=".mdkg/config.json" />
        <FeatureCard title="Custom skill mirrors" text="Mirror canonical `.mdkg/skills` into arbitrary contained agent-local skill roots. `.agents/skills` and `.claude/skills` remain defaults." command="mdkg skill sync" />
        <FeatureCard title="Collaboration profile" text="Use `COLLABORATION.md` as the canonical operator profile while `HUMAN.md` remains a one-release legacy alias." command="COLLABORATION.md" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div class="stack">
        <Badge tone="teal">Handoffs</Badge>
        <h2>Transfer agent work without raw history dumps.</h2>
        <p class="muted">`mdkg handoff create` builds a bounded handoff from goal/work state, latest checkpoints, boundaries, required checks, next actions, and safety warnings.</p>
      </div>
      <TerminalBlock
        title="Handoff"
        commands={["mdkg goal next", "mdkg pack WORK_ID --profile concise", "mdkg handoff create WORK_ID", "mdkg task done TASK_ID --checkpoint \"Meaningful milestone\""]}
      />
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeader
        eyebrow="Advanced alpha"
        title="Advanced surfaces stay optional."
        text="These capabilities help larger agentic workflows, but users do not need them to understand or try the core loop."
      />
      <div class="grid three">
        <FeatureCard title="Read-only MCP" text="Let agents inspect project memory without mutation, shell, SQL, or environment access." />
        <FeatureCard title="Subgraphs and bundles" text="Plan across nested repos through read-only qids and deterministic bundle snapshots." />
        <FeatureCard title="Local queues" text="Advanced project DB queue workflows are local delivery state, not hosted execution history." />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta-panel">
      <div class="stack">
        <Badge tone="neutral">Public alpha</Badge>
        <h2>Try it on a small repo first.</h2>
        <p class="muted">If this problem feels familiar, try the quickstart and star the repo if mdkg seems useful. If your agents lose context in a different way, open an issue; real workflow pain is shaping the public-alpha roadmap.</p>
      </div>
      <CTAGroup
        primaryHref="/quickstart/"
        primaryLabel="Run the quickstart"
        secondaryHref="https://github.com/nickreames/mdkg"
        secondaryLabel="Star on GitHub"
        tertiaryHref="https://github.com/nickreames/mdkg/issues"
        tertiaryLabel="Send feedback"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(280px, 0.98fr);
    gap: 28px;
    align-items: center;
  }

  .pwe-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .pwe-card {
    position: relative;
    display: grid;
    gap: 14px;
    min-height: 260px;
    padding: 22px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--white);
    box-shadow: var(--shadow);
  }

  .pwe-card:not(:last-child)::after {
    content: "->";
    position: absolute;
    top: 28px;
    right: -16px;
    z-index: 1;
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--blue-700);
    background: var(--white);
    font-family: var(--font-mono);
    font-weight: 800;
  }

  .pwe-card p {
    color: var(--zinc-600);
  }

  .pwe-card code {
    align-self: end;
    width: fit-content;
    max-width: 100%;
    padding: 7px 9px;
    border-radius: var(--radius);
    color: var(--blue-700);
    background: var(--sky-50);
    font-size: 0.82rem;
    overflow-wrap: anywhere;
    white-space: normal;
  }

  .pwe-label {
    width: fit-content;
    padding: 5px 8px;
    border-radius: var(--radius);
    color: var(--zinc-950);
    background: var(--zinc-100);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .plan-card {
    background: linear-gradient(180deg, var(--white), var(--sky-50));
  }

  .work-card {
    background: linear-gradient(180deg, var(--white), var(--teal-50));
  }

  .evidence-card {
    background: linear-gradient(180deg, var(--white), var(--zinc-50));
  }

  .proof-card {
    padding: 22px;
    border: 1px solid rgba(14, 165, 233, 0.22);
    border-radius: var(--radius);
    background:
      linear-gradient(180deg, var(--white), var(--sky-50)),
      var(--white);
    box-shadow: var(--shadow);
  }

  .path-line,
  .proof-footer {
    font-family: var(--font-mono);
    font-size: 0.84rem;
  }

  .path-line {
    padding: 9px 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--blue-700);
    background: var(--white);
    overflow-wrap: anywhere;
  }

  dl {
    display: grid;
    gap: 12px;
    margin: 18px 0;
  }

  dt {
    color: var(--zinc-950);
    font-family: var(--font-mono);
    font-size: 0.84rem;
    font-weight: 700;
  }

  dd {
    margin: 4px 0 0;
    color: var(--zinc-600);
    overflow-wrap: anywhere;
  }

  .proof-footer {
    color: #0f766e;
  }

  .comparison-card {
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--zinc-50);
  }

  .comparison-card.positive {
    background: linear-gradient(180deg, var(--teal-50), var(--white));
    border-color: rgba(20, 184, 166, 0.34);
  }

  .comparison-card ul {
    display: grid;
    gap: 8px;
    margin: 14px 0 0;
    padding-left: 18px;
    color: var(--zinc-700);
  }

  .cta-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: center;
    padding: 28px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: linear-gradient(135deg, var(--sky-50), var(--white), var(--teal-50));
  }

  .cta-panel :global(.cta-group) {
    margin-top: 0;
    justify-content: flex-end;
  }

  @media (max-width: 820px) {
    .comparison-grid,
    .pwe-grid,
    .proof-grid,
    .cta-panel {
      grid-template-columns: 1fr;
    }

    .cta-panel :global(.cta-group) {
      justify-content: flex-start;
    }

    .pwe-card:not(:last-child)::after {
      top: auto;
      right: 50%;
      bottom: -16px;
      transform: translateX(50%) rotate(90deg);
    }
  }
</style>
