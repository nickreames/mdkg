---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAGroup from "../components/CTAGroup.astro";
import SectionHeader from "../components/SectionHeader.astro";
import TerminalBlock from "../components/TerminalBlock.astro";
import FeatureCard from "../components/FeatureCard.astro";
import DiagramCard from "../components/DiagramCard.astro";
import ClaimEvidenceCard from "../components/ClaimEvidenceCard.astro";
import Badge from "../components/Badge.astro";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Markdown Knowledge Graph",
  alternateName: "mdkg",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux, Windows",
  softwareVersion: "0.3.7",
  description: "Git-native project memory for AI-native software engineering.",
  url: "https://mdkg.dev",
  codeRepository: "https://github.com/nickreames/mdkg"
};
---

<BaseLayout
  title="Markdown Knowledge Graph - Git-native project memory"
  description="Markdown Knowledge Graph turns structured Markdown in your repo into deterministic context packs, goals, checkpoints, skills, and handoffs."
  structuredData={structuredData}
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Markdown Knowledge Graph</p>
        <h1>Git-native project memory for AI-native software engineering.</h1>
        <p class="lead">Turn structured Markdown in your repo into deterministic context packs, goals, checkpoints, skills, and handoffs for humans and AI agents - without a daemon, hosted index, vector database, or hidden cloud state.</p>
        <p class="trust-line">Developer preview. Pre-v1 public alpha. Markdown is the source of truth; local indexes are rebuildable.</p>
        <CTAGroup />
      </div>
      <DiagramCard
        title="Repo memory loop"
        steps={["Markdown + frontmatter in Git", "mdkg index / validate", "deterministic pack / handoff", "human or AI agent works", "checkpoint + evidence"]}
      />
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div class="stack">
        <Badge>Quickstart</Badge>
        <h2>Start with the golden loop.</h2>
        <p class="muted">Initialize repo-local project memory, build the access cache, inspect status, validate graph health, then give an agent a bounded pack or handoff.</p>
      </div>
      <TerminalBlock
        title="First run"
        commands={["npm install -g mdkg", "mdkg init --agent", "mdkg index", "mdkg status", "mdkg validate"]}
      />
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeader
        eyebrow="Why it exists"
        title="AI coding agents lose the thread."
        text="Goals disappear into chat history. Architecture decisions drift across files and prompts. Agents confuse background context with executable scope. Handoffs become raw context dumps."
      />
      <div class="grid three">
        <FeatureCard title="Project memory in Git" text="Keep goals, tasks, decisions, evidence, and handoffs in files that humans and agents can inspect." command=".mdkg/work" />
        <FeatureCard title="Deterministic packs" text="Build focused context from graph state instead of asking an agent to browse randomly." command="mdkg pack <id>" />
        <FeatureCard title="Evidence before closeout" text="Record checkpoints and run validation before moving on to the next node." command="mdkg validate" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Model"
        title="Work, context, and evidence are different things."
        text="mdkg separates executable scope from background context and proof, so agents can see what to do, what to know, and what supports the current state."
      />
      <div class="grid three">
        <ClaimEvidenceCard claim="scope_refs" evidence="Actionable nodes such as tasks, tests, bugs, features, and spikes." caveat="This is what a goal can route through." />
        <ClaimEvidenceCard claim="context_refs" evidence="Design records, PRDs, decisions, prior goals, and background sources." caveat="Context informs work but is not automatically actionable." />
        <ClaimEvidenceCard claim="evidence_refs" evidence="Checkpoints, archive sidecars, receipts, and proof artifacts." caveat="Evidence supports state without dumping raw execution traces." />
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeader
        eyebrow="Markdown plus Git"
        title="Project memory should be boring, inspectable, and version-controlled."
        text="Markdown stays readable. Frontmatter gives machines structure. Git gives review, history, branching, and collaboration. Generated indexes stay rebuildable."
      />
      <div class="grid three">
        <FeatureCard title="Source files" text="Rules, decisions, PRDs, work nodes, checkpoints, skills, and archive sidecars live in the repo." command=".mdkg/" />
        <FeatureCard title="Generated access" text="Indexes and packs make retrieval fast without becoming hidden authority." command="mdkg index" />
        <FeatureCard title="Optional local DB" text="SQLite supports advanced local infrastructure but Markdown remains canonical." command="mdkg db verify" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div class="stack">
        <Badge tone="teal">Handoffs</Badge>
        <h2>Transfer agent work without raw history dumps.</h2>
        <p class="muted">`mdkg handoff create` builds a bounded handoff from goal/work state, latest checkpoints, boundaries, required checks, next actions, and safety warnings.</p>
      </div>
      <TerminalBlock
        title="Handoff"
        commands={["mdkg goal next", "mdkg pack <id> --pack-profile concise", "mdkg handoff create <id>", "mdkg task done <id> --checkpoint \"Meaningful milestone\""]}
      />
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeader
        eyebrow="Agent workflow"
        title="Model the work agents need to follow."
        text="Goals, tasks, tests, bugs, features, spikes, and checkpoints give AI coding sessions durable shape without turning mdkg into an executor."
      />
      <div class="flow">
        <div class="flow-step"><span class="flow-index">1</span><div><strong>Find the next node.</strong><p class="muted">Use <code>mdkg goal next</code> and <code>mdkg pack &lt;id&gt;</code> before editing.</p></div></div>
        <div class="flow-step"><span class="flow-index">2</span><div><strong>Do the work outside mdkg.</strong><p class="muted">A human or agent changes code, docs, tests, or graph nodes.</p></div></div>
        <div class="flow-step"><span class="flow-index">3</span><div><strong>Record evidence.</strong><p class="muted">Close with checkpoints, validation, and handoffs.</p></div></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Trust gates"
        title="Validate before you close the loop."
        text="Status, doctor, fix planning, formatting, and validation make mdkg useful in real branches with humans and agents creating state."
      />
      <div class="grid three">
        <FeatureCard title="Status" text="Operator summary for graph, git, selected goal, cache, and project DB state." command="mdkg status" />
        <FeatureCard title="Doctor" text="Strict diagnostics with remediation for scriptable health checks." command="mdkg doctor --strict --json" />
        <FeatureCard title="Fix planning" text="Dry-run-first repair planning for index, references, and ID conflicts." command="mdkg fix plan --json" />
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <SectionHeader
        eyebrow="Advanced alpha"
        title="Depth for larger agentic workflows, secondary to the first-run path."
        text="These surfaces are documented for early adopters, but users do not need them to understand the core value."
      />
      <div class="grid three">
        <FeatureCard title="Read-only MCP" text="Let agents inspect project memory without mutation, shell, SQL, or environment access." />
        <FeatureCard title="Subgraphs and bundles" text="Plan across nested repos through read-only qids and deterministic bundle snapshots." />
        <FeatureCard title="Local queues" text="Advanced project DB queue workflows are local delivery state, not hosted execution history." />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div class="stack">
        <Badge tone="neutral">Origin</Badge>
        <h2>Built from the same file-first agent workflow it teaches.</h2>
        <p class="muted">Markdown Knowledge Graph grew out of Nicholas Reames's own AI coding workflow: durable files, frontmatter, reusable instructions, checkpoints, and deterministic context instead of hidden chat memory.</p>
      </div>
      <ClaimEvidenceCard
        claim="Public-alpha honesty"
        evidence="The site links core shipped commands to generated reference docs and keeps deferred worker execution, hosted queues, analytics, DNS, and production launch out of scope."
        caveat="This goal proves local pre-release readiness, not a public deployment."
      />
    </div>
  </section>
</BaseLayout>
