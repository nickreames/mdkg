---
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const {
  title = "Markdown Knowledge Graph",
  description = "Git-native project memory for AI coding agents.",
  noindex = false,
  structuredData
} = Astro.props;
const siteUrl = "https://mdkg.dev";
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const socialImage = new URL("/social-card.svg", siteUrl).toString();
const productionIndexOptIn = String(import.meta.env.PUBLIC_MDKG_PRODUCTION_INDEX || "").toLowerCase() === "true";
const vercelPrelaunchNoindex = import.meta.env.VERCEL === "1" && !productionIndexOptIn;
const previewNoindex =
  import.meta.env.VERCEL_ENV === "preview" ||
  String(import.meta.env.PUBLIC_MDKG_PREVIEW_NOINDEX || "").toLowerCase() === "true" ||
  vercelPrelaunchNoindex;
const robotsContent = noindex || previewNoindex ? "noindex, nofollow" : "index, follow";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Markdown Knowledge Graph" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Markdown Knowledge Graph social card" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content="Markdown Knowledge Graph social card" />
    {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
  </head>
  <body>
    <div class="page">
      <NavBar />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
