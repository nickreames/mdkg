{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mdkg-dev.vercel.app"
        }
      ],
      "destination": "https://mdkg.dev/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mdkg-dev-nicholas-reames-projects.vercel.app"
        }
      ],
      "destination": "https://mdkg.dev/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mdkg-dev-git-main-nicholas-reames-projects.vercel.app"
        }
      ],
      "destination": "https://mdkg.dev/:path*",
      "permanent": true
    },
    {
      "source": "/docs",
      "destination": "https://docs.mdkg.dev/",
      "permanent": true
    },
    {
      "source": "/docs/",
      "destination": "https://docs.mdkg.dev/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": ".*\\.vercel\\.app$"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
