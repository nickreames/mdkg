{
  "redirects": [
    {
      "source": "/docs",
      "destination": "https://docs.mdkg.dev/",
      "permanent": true
    },
    {
      "source": "/docs/",
      "destination": "https://docs.mdkg.dev/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": ".*\\.vercel\\.app$"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
